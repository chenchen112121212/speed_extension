{
  "manifest_version": 3,
  "name": "CCB Speed Controller",
  "version": "1.0.1",
  "description": "CCB挂课系统速度控制扩展",
  "permissions": [],
  "host_permissions": ["https://u.ccb.com/*"],
  "content_scripts": [
    {
      "matches": ["https://u.ccb.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}